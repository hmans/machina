{
  "schema_version": 1,
  "timeout_frames": 180,
  "actions": [
    {"action": "click", "target": {"text": "STOP", "origin": "editor"}},
    {"action": "wait", "frames": 2},
    {"action": "click", "target": {"text": "Title", "origin": "editor"}},
    {"action": "wait", "frames": 2},
    {"action": "type", "target": {"text": "SCRAPBOT UI", "origin": "editor"}, "text": "REFLECTED TITLE"},
    {"action": "key", "key": "enter"},
    {"action": "wait", "frames": 2},
    {"action": "expect", "target": {"text": "REFLECTED TITLE", "origin": "editor"}, "expect": "text", "text": "REFLECTED TITLE"},
    {"action": "expect", "target": {"name": "__scrapbot_editor_status_text", "origin": "editor"}, "expect": "text", "text": "STOPPED  /  UNSAVED"},
    {"action": "click", "target": {"text": "UNDO", "origin": "editor"}},
    {"action": "wait", "frames": 2},
    {"action": "expect", "target": {"text": "SCRAPBOT UI", "origin": "editor"}, "expect": "text", "text": "SCRAPBOT UI"},
    {"action": "expect", "target": {"name": "__scrapbot_editor_status_text", "origin": "editor"}, "expect": "text", "text": "STOPPED"},
    {"action": "capture", "target": {"name": "__scrapbot_editor_inspector_panel_1", "origin": "editor"}, "padding": 8}
  ]
}
